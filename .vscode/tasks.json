{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ui:dev",
      "type": "shell",
      "command": "bun",
      "args": ["run", "dev"],
      "isBackground": true,
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": { "regexp": "^$" },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "vite v",
            "endsPattern": "ready in"
          }
        }
      ]
    },
    {
      "label": "ui:build",
      "type": "shell",
      "command": "bun",
      "args": ["run", "build"],
      "options": { "cwd": "${workspaceFolder}" }
    }
  ]
}
